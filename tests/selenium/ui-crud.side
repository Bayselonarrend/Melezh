    {
      "id": "e8f9a0b1-c2d3-4567-e8f9-a0b1c2d34567",
      "name": "Load logs for echo_get",
      "commands": [
        {
          "id": "e8f9a0b1-c2d3-4567-e8f9-a0b1c2d34569",
          "command": "run",
          "target": "_Login",
          "value": ""
        },
        {
          "id": "e8f9a0b1-c2d3-4567-e8f9-a0b1c2d3456a0",
          "command": "executeScript",
          "target": "return fetch('/echo_get?field2=selenium&field3=selenium').then(function(r){return r.json();}).then(function(b){if(!b||!b.result){throw new Error('echo_get failed');}return fetch('api/getLastEvents');}).then(function(r){return r.json();}).then(function(res){if(!res.result||!res.data||!res.data.length){throw new Error('no last events');}var ev=res.data.find(function(e){return e.handler==='echo_get';})||res.data[0];var s=String(ev.date);var ds=/^\\d{4}-\\d{2}-\\d{2}/.test(s)?s.substring(0,10):(function(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');})(new Date(ev.date));return fetch('api/getEvents?handler=echo_get&date='+ds).then(function(r){return r.json();}).then(function(evRes){if(!evRes.result||!evRes.data||!evRes.data.length){throw new Error('no log files for '+ds);}window.location.hash='#logs?handler=echo_get&date='+ds;return ds;});});",
          "value": ""
        },
        {
          "id": "e8f9a0b1-c2d3-4567-e8f9-a0b1c2d3456b",
          "command": "waitForElementPresent",
          "target": "xpath=//h2[contains(.,'Просмотр логов') or contains(.,'Log Viewer')]",
          "value": "15000"
        },
        {
          "id": "e8f9a0b1-c2d3-4567-e8f9-a0b1c2d34570",
          "command": "waitForElementPresent",
          "target": "xpath=//tbody//code[contains(.,'echo_get')]",
          "value": "15000"
        }
      ]
    }

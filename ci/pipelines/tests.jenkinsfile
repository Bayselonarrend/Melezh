pipeline {
	agent {
		label 'windows'
	}
    stages {

        stage('Restart Docker Containers') {
            steps {
                script {
                    restartDockerContainers()
                }
            }
        }

        stage('CLI Test (RU)') {
            steps {
                    bat encoding: 'UTF-8', script:'chcp 65001 & oneunit e -f ./tests/tests_ru.os'
            }
        }

        stage('CLI Test (EN)') {
            steps {
                    bat encoding: 'UTF-8', script:'chcp 65001 & oneunit e -f ./tests/tests_en.os'
            }
        }

        stage('Requests Test') {
            steps {
                    bat encoding: 'UTF-8', script:'chcp 65001 & oneunit e -f ./tests/tests_handlers.os'
            }
        }

        stage('Main UI Tests (RPM, RU)') {
            steps {
                retry(3) {
                    bat 'npm install selenium-side-runner --save-dev'
                    bat 'npx selenium-side-runner ./tests/selenium/tests.side --timeout 300000 --base-url http://localhost:1921 --retries 3 -c "browserName=chrome goog:chromeOptions.args=[--headless=new,--disable-gpu,--no-sandbox,--disable-dev-shm-usage,--disable-software-rasterizer,--window-size=1920,1080,--remote-debugging-port=9222]"'
                }
            }
        }
    }
}

def restartDockerContainers() {
    bat """
        cd service\\docker
        docker-compose down --remove-orphans
        docker-compose down --rmi all
        docker-compose pull
        docker-compose up -d --force-recreate
    """
}